`pragma protect end_protected
module PSRAM_Memory_Interface_HS_Top (
  clk,
  rst_n,
  memory_clk,
  pll_lock,
  O_psram_ck,
  O_psram_ck_n,
  IO_psram_rwds,
  O_psram_reset_n,
  IO_psram_dq,
  O_psram_cs_n,
  init_calib0,
  init_calib1,
  clk_out,
  cmd0,
  cmd1,
  cmd_en0,
  cmd_en1,
  addr0,
  addr1,
  wr_data0,
  wr_data1,
  rd_data0,
  rd_data1,
  rd_data_valid0,
  rd_data_valid1,
  data_mask0,
  data_mask1
)
;
input clk;
input rst_n;
input memory_clk;
input pll_lock;
output [1:0] O_psram_ck;
output [1:0] O_psram_ck_n;
inout [1:0] IO_psram_rwds;
output [1:0] O_psram_reset_n;
inout [15:0] IO_psram_dq;
output [1:0] O_psram_cs_n;
output init_calib0;
output init_calib1;
output clk_out;
input cmd0;
input cmd1;
input cmd_en0;
input cmd_en1;
input [20:0] addr0;
input [20:0] addr1;
input [31:0] wr_data0;
input [31:0] wr_data1;
output [31:0] rd_data0;
output [31:0] rd_data1;
output rd_data_valid0;
output rd_data_valid1;
input [3:0] data_mask0;
input [3:0] data_mask1;
wire n16_5;
wire dll_lock;
wire clk_x2;
wire n5_6;
wire n18_6;
wire stop;
wire dll_rsti;
wire uddcntln;
wire ddr_rsti;
wire dll_lock_d;
wire wr_data_d_0_5;
wire [7:0] dll_step;
wire [3:3] cs_memsync;
wire VCC;
wire GND;
  LUT2 n16_s1 (
    .F(n16_5),
    .I0(cs_memsync[3]),
    .I1(dll_rsti) 
);
defparam n16_s1.INIT=4'h1;
  DLL u_dll (
    .STEP(dll_step[7:0]),
    .LOCK(dll_lock),
    .UPDNCNTL(uddcntln),
    .STOP(n5_6),
    .CLKIN(clk_x2),
    .RESET(dll_rsti) 
);
defparam u_dll.CODESCAL="101";
defparam u_dll.DIV_SEL=1'b0;
defparam u_dll.DLL_FORCE=0;
defparam u_dll.SCAL_EN="false";
  DHCEN u_dhcen_clk_x2 (
    .CLKOUT(clk_x2),
    .CLKIN(memory_clk),
    .CE(stop) 
);
  CLKDIV clkdiv (
    .CLKOUT(clk_out),
    .CALIB(GND),
    .HCLKIN(clk_x2),
    .RESETN(n16_5) 
);
defparam clkdiv.DIV_MODE="2";
defparam clkdiv.GSREN="false";
  INV n5_s2 (
    .O(n5_6),
    .I(pll_lock) 
);
  INV n18_s2 (
    .O(n18_6),
    .I(rst_n) 
);
  \~psram_sync.PSRAM_Memory_Interface_HS_Top  u_psram_sync (
    .pll_lock(pll_lock),
    .clk(clk),
    .n18_6(n18_6),
    .stop(stop),
    .dll_rsti(dll_rsti),
    .uddcntln(uddcntln),
    .ddr_rsti(ddr_rsti),
    .O_psram_reset_n(O_psram_reset_n[0]),
    .cs_memsync(cs_memsync[3])
);
  \~psram_memory_interface.PSRAM_Memory_Interface_HS_Top  u_psram_top0 (
    .clk_out_d(clk_out),
    .ddr_rsti(ddr_rsti),
    .dll_lock(dll_lock),
    .clk_x2(clk_x2),
    .cmd_en0(cmd_en0),
    .cmd0(cmd0),
    .wr_data0(wr_data0[31:0]),
    .addr0(addr0[20:0]),
    .data_mask0(data_mask0[3:0]),
    .dll_step(dll_step[7:0]),
    .rd_data_valid0(rd_data_valid0),
    .dll_lock_d(dll_lock_d),
    .wr_data_d_0_5(wr_data_d_0_5),
    .init_calib0(init_calib0),
    .rd_data0(rd_data0[31:0]),
    .O_psram_ck(O_psram_ck[0]),
    .O_psram_ck_n(O_psram_ck_n[0]),
    .O_psram_cs_n(O_psram_cs_n[0]),
    .IO_psram_dq(IO_psram_dq[7:0]),
    .IO_psram_rwds(IO_psram_rwds[0])
);
  \~psram_memory_interface.PSRAM_Memory_Interface_HS_Top_0  u_psram_top1 (
    .clk_out_d(clk_out),
    .ddr_rsti(ddr_rsti),
    .dll_lock_d(dll_lock_d),
    .clk_x2(clk_x2),
    .cmd_en1(cmd_en1),
    .wr_data_d_0_5(wr_data_d_0_5),
    .cmd1(cmd1),
    .wr_data1(wr_data1[31:0]),
    .addr1(addr1[20:0]),
    .data_mask1(data_mask1[3:0]),
    .dll_step(dll_step[7:0]),
    .rd_data_valid1(rd_data_valid1),
    .init_calib1(init_calib1),
    .rd_data1(rd_data1[31:0]),
    .O_psram_ck(O_psram_ck[1]),
    .O_psram_ck_n(O_psram_ck_n[1]),
    .O_psram_cs_n(O_psram_cs_n[1]),
    .IO_psram_dq(IO_psram_dq[15:8]),
    .IO_psram_rwds(IO_psram_rwds[1])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
assign O_psram_reset_n[1] = O_psram_reset_n[0];
endmodule /* PSRAM_Memory_Interface_HS_Top */

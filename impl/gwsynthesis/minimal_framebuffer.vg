wire n168_9;
wire n71_10;
wire n76_10;
wire n63_10;
wire n67_11;
wire button_sync_1;
wire button_sync_0;
wire [20:0] counter;
wire VCC;
wire GND;
  LUT4 n168_s0 (
    .F(n168_3),
    .I0(n168_4),
    .I1(switch_buffer),
    .I2(button_sync_1),
    .I3(counter[20]) 
);
defparam n168_s0.INIT=16'h1400;
  LUT2 n78_s2 (
    .F(n78_7),
    .I0(counter[0]),
    .I1(n78_8) 
);
defparam n78_s2.INIT=4'h4;
  LUT3 n77_s2 (
    .F(n77_7),
    .I0(counter[1]),
    .I1(counter[0]),
    .I2(n78_8) 
);

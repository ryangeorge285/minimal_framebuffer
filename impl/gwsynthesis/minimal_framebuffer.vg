`pragma protect end_protected
module PSRAM_Memory_Interface_HS_Top (
  memory_clk,
  memory_pll_lock,
  sys_resetn_d,
  sys_clk_d,
  \addr[0] ,
  cmd_en,
  cmd,
  \addr[1] ,
  clk,
  n18_6,
  rvld,
  rvld_0,
  O_psram_ck,
  O_psram_ck_n,
  O_psram_cs_n,
  O_psram_reset_n_d,
  mth_rf_od,
  init_calib,
  mth_rf_od_1,
  init_calib_2,
  IO_psram_dq,
  IO_psram_rwds
)
;
input memory_clk;
input memory_pll_lock;
input sys_resetn_d;
input sys_clk_d;
input [20:6] \addr[0] ;
input [1:0] cmd_en;
input [1:0] cmd;
input [20:6] \addr[1] ;
output clk;
output n18_6;
output rvld;
output rvld_0;
output [1:0] O_psram_ck;
output [1:0] O_psram_ck_n;
output [1:0] O_psram_cs_n;
output [1:1] O_psram_reset_n_d;
output [31:0] mth_rf_od;
output [0:0] init_calib;
output [31:0] mth_rf_od_1;
output [1:1] init_calib_2;
inout [15:0] IO_psram_dq;
inout [1:0] IO_psram_rwds;
wire n16_5;
wire dll_lock;
wire clk_x2;
wire n5_6;
wire ddr_rsti;
wire stop;
wire dll_rsti;
wire uddcntln;
wire dll_lock_d;
wire wr_data_d_0_5;
wire [7:0] dll_step;
wire [3:3] cs_memsync;
wire VCC;
wire GND;
  LUT2 n16_s1 (
    .F(n16_5),
    .I0(cs_memsync[3]),

module FIFO_HS_Top_Read (
  n134_4,
  fifo_wr_en,
  pix_clk,
  clk,
  fifo_wr_data,
  fifo_read_empty,
  videoclk_fifo_read_almost_empty,
  pixel
)
;
input n134_4;
input fifo_wr_en;
input pix_clk;
input clk;
input [31:0] fifo_wr_data;
output fifo_read_empty;
output videoclk_fifo_read_almost_empty;
output [15:0] pixel;
wire VCC;
wire GND;
  \~fifo.FIFO_HS_Top_Read  fifo_inst (
    .n134_4(n134_4),
    .fifo_wr_en(fifo_wr_en),
    .pix_clk(pix_clk),
    .clk(clk),
    .fifo_wr_data(fifo_wr_data[31:0]),
    .fifo_read_empty(fifo_read_empty),
    .videoclk_fifo_read_almost_empty(videoclk_fifo_read_almost_empty),
    .pixel(pixel[15:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* FIFO_HS_Top_Read */
module cdc (
  clk,
  n18_6,
  videoclk_fifo_read_almost_empty,
  plclk_fifo_read_almost_empty_sync
)
;
input clk;
input n18_6;
input videoclk_fifo_read_almost_empty;
output plclk_fifo_read_almost_empty_sync;
wire sync1;
wire VCC;
wire GND;
  DFFC sync2_s0 (
    .Q(plclk_fifo_read_almost_empty_sync),
    .D(sync1),
    .CLK(clk),
    .CLEAR(n18_6) 
);
  DFFC sync1_s0 (
    .Q(sync1),
    .D(videoclk_fifo_read_almost_empty),
    .CLK(clk),
    .CLEAR(n18_6) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* cdc */
